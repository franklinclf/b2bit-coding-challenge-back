# Configuracoes Django
SECRET_KEY=django-insecure-key-for-dev-only-change-in-production
DEBUG=True
TIME_ZONE=UTC
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,cine-reserve
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Configuracoes de Banco
POSTGRES_DB=cine_reserve_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Configuracoes Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Cache e Lock de Assentos
CACHE_DEFAULT_TIMEOUT=300
SEAT_LOCK_TIMEOUT_SECONDS=600
MOVIES_LIST_CACHE_TTL=120
SESSIONS_LIST_CACHE_TTL=120

# Configuracoes de Email
DEFAULT_FROM_EMAIL=noreply@cinereserve.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Limite de Taxa da API
THROTTLE_ANON_RATE=100/hour
THROTTLE_USER_RATE=1000/hour
THROTTLE_LOGIN_RATE=20/minute
THROTTLE_REGISTER_RATE=10/minute
THROTTLE_SEAT_RESERVATION_RATE=60/minute
THROTTLE_CHECKOUT_RATE=30/minute

# Opcional: Criacao de Superusuario
CREATE_SUPERUSER=false
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Sobrescritas do Docker Compose
APP_PORT=8000
PG_PORT=5432
